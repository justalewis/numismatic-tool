# Copy this file to .env.local and fill in your key(s).
# On Vercel, set these in Project Settings -> Environment Variables
# (do NOT commit the real keys).

# Required: powers the grading model.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables Numista catalogue grounding for identification/attribution.
# Without it, the grader still runs and attributes from the model's own
# knowledge. Request a key at https://en.numista.com/api/
NUMISTA_API_KEY=

# Optional: password-gate the whole app (page + API) with HTTP Basic Auth.
# Set BOTH to enable; leave unset to run ungated (fine for local dev). In
# production these are set as Fly secrets, not in this file.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
